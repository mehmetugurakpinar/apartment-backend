        },
        {
          "name": "Create Dues Plan",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/dues",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"March 2026 Dues\",\n  \"amount\": 500.00,\n  \"period_month\": 3,\n  \"period_year\": 2026,\n  \"due_date\": \"2026-03-15\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data) {",
                "  pm.collectionVariables.set('planId', jsonData.data.id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Update Dues Plan",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/dues/{{planId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"March 2026 Dues (Updated)\",\n  \"amount\": 600.00,\n  \"period_month\": 3,\n  \"period_year\": 2026,\n  \"due_date\": \"2026-03-20\"\n}"
            }
          }
        },
        {
          "name": "Delete Dues Plan",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/dues/{{planId}}"
          }
        },
        {
          "name": "Pay Dues (Record Payment)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/dues/{{planId}}/pay",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unit_id\": \"{{unitId}}\",\n  \"paid_amount\": 500.00,\n  \"notes\": \"Paid via bank transfer\"\n}"
            }
          }
        },
        {
          "name": "Get Dues Report",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/dues/report",
            "url": {
              "raw": "{{baseUrl}}/buildings/{{buildingId}}/dues/report?month=3&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["buildings", "{{buildingId}}", "dues", "report"],
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2026" }
              ]
            }
          }
        }
      ]
    },
