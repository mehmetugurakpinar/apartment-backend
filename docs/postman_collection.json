              "mode": "raw",
              "raw": "{\n  \"unit_id\": \"{{unitId}}\",\n  \"title\": \"Water leak in bathroom\",\n  \"description\": \"There is a water leak under the sink\",\n  \"priority\": \"high\"\n}"
