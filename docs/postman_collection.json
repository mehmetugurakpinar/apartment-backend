            "url": "{{baseUrl}}/buildings/{{buildingId}}/maintenance/{{reqId}}/reject"
          }
        },
        {
          "name": "Delete Request",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/buildings/{{buildingId}}/maintenance/{{reqId}}"
          }
        }
