              "raw": "{\n  \"name\": \"Sunset Apartments\",\n  \"address\": \"123 Main St\",\n  \"city\": \"Istanbul\",\n  \"total_units\": 24,\n  \"latitude\": 41.0082,\n  \"longitude\": 28.9784\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
