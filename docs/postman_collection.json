{
  "info": {
    "name": "Apartment Management API",
    "description": "Complete API collection for the Apartment Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "buildingId", "value": "" },
    { "key": "unitId", "value": "" },
    { "key": "planId", "value": "" },
    { "key": "reqId", "value": "" },
    { "key": "vendorId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "pollId", "value": "" },
    { "key": "optionId", "value": "" },
    { "key": "notifId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"John Doe\",\n  \"phone\": \"+905551234567\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data) {",
                "  pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                "  pm.collectionVariables.set('refreshToken', jsonData.data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data) {",
                "  pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                "  pm.collectionVariables.set('refreshToken', jsonData.data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data) {",
                "  pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                "  pm.collectionVariables.set('refreshToken', jsonData.data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/accept-invitation",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"invitation-token-here\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Updated\",\n  \"phone\": \"+905559876543\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newPassword456\"\n}"
            }
          }
        }
      ]
    },
    {
